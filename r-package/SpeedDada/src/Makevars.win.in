# Generated by ./configure.win — do not edit directly; edit Makevars.win.in.
WORKSPACE_ROOT = @WORKSPACE_ROOT@
CARGO          = @CARGO@
TARGET         = @TARGET@

RUST_LIB = $(WORKSPACE_ROOT)/target/$(TARGET)/release/libspeeddada_r.a

# Windows imports pulled in by the Rust standard library (winapi).
WINAPI_LIBS = -lws2_32 -luserenv -lbcrypt -lntdll -lkernel32 -ladvapi32

# Link the static Rust archive plus needed Windows imports + libbz2 (shipped
# with Rtools' MinGW64 toolchain).
PKG_LIBS   = $(RUST_LIB) $(WINAPI_LIBS) -lbz2 -lpthread
PKG_CFLAGS =

all: $(SHLIB)

$(SHLIB): $(RUST_LIB)

$(RUST_LIB):
	cd $(WORKSPACE_ROOT) && $(CARGO) build --release --target=$(TARGET) -p speeddada-r
