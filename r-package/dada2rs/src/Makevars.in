# Generated by ./configure — do not edit directly; edit Makevars.in instead.
WORKSPACE_ROOT = @WORKSPACE_ROOT@
CARGO          = @CARGO@

RUST_LIB = $(WORKSPACE_ROOT)/target/release/libdada2_r.a

# Link the static Rust archive plus required system libraries.
PKG_LIBS   = $(RUST_LIB) -lpthread -ldl -lm -lbz2
PKG_CFLAGS =

all: $(SHLIB)

# Ensure the Rust library is built before the C linker runs.
$(SHLIB): $(RUST_LIB)

$(RUST_LIB):
	cd $(WORKSPACE_ROOT) && $(CARGO) build --release -p dada2-r
