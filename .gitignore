# Rust build artefacts
target/

# R package build artefacts (generated by ./configure on R CMD INSTALL —
# machine-local; source of truth is Makevars.in / Makevars.win.in).
r-package/SpeedDada/src/*.so
r-package/SpeedDada/src/*.o
r-package/SpeedDada/src/*.dll
r-package/SpeedDada/src/Makevars
r-package/SpeedDada/src/Makevars.win

# Vendored Rust source for distributable R tarballs — produced on demand by
# `tools/vendor-r-rust.sh`; never committed (duplicates crates/ tree).
r-package/SpeedDada/src/rust/

# R CMD build outputs
*.tar.gz
SpeedDada.Rcheck/

# Python build / venv artefacts
*.egg-info/
__pycache__/
*.pyc
.venv/
crates/speeddada-py/dist/
crates/speeddada-py/build/

# Benchmark outputs
bench_logs/

# OS metadata
.DS_Store

# Claude state — tracked only on the `claude-state` orphan branch in
# wurstator/speed-dada (private). Never on `main`, which is shared with
# the public genedance/speed-dada mirror.
.claude/
